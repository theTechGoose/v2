{
  "nodeModulesDir": "manual",
  "tasks": {
    "build": "cd front-end && PATH=\"$PWD/../node_modules/.bin:$PATH\" deno task build",
    "start": "deno serve -A --unstable-kv mod.ts",
    "start:local": "deno serve -A --unstable-kv --env-file=.env mod.ts",
    "serve": "deno run -A --unstable-kv serve.ts",
    "test:e2e": "deno run -A --unstable-kv tests/e2e.ts"
  },
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}
