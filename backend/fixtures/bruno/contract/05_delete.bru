delete {
  url: {{baseUrl}}/contracts/{{contractId}}
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("ok flag", function() {
    expect(res.getBody().ok).to.equal(true);
  });
}
