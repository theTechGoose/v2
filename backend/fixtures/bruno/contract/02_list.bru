meta {
  name: 02 list contracts
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/contracts
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("contains created contract", function() {
    const ids = res.getBody().map((c) => c.id);
    expect(ids).to.include(bru.getVar("contractId"));
  });
}
