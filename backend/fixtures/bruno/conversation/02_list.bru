meta {
  name: 02 list conversations
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/conversations
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("contains created conversation", function() {
    const ids = res.getBody().map((c) => c.id);
    expect(ids).to.include(bru.getVar("conversationId"));
  });
}
