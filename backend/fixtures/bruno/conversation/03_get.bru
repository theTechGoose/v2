meta {
  name: 03 get conversation
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/conversations/{{conversationId}}
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("id matches", function() {
    expect(res.getBody().id).to.equal(bru.getVar("conversationId"));
  });
}
