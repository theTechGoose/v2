meta {
  name: 01 create conversation
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/conversations
  body: json
  auth: none
}

body:json {
  {
    "title": "Acme — water heater follow-up"
  }
}

script:post-response {
  bru.setVar("conversationId", res.getBody().id);
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("returns id", function() {
    expect(res.getBody().id).to.be.a("string");
  });
  test("title preserved", function() {
    expect(res.getBody().title).to.equal("Acme — water heater follow-up");
  });
}
