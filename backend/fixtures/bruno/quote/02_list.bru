meta {
  name: 02 list quotes
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/quotes
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("contains created quote", function() {
    const ids = res.getBody().map((q) => q.id);
    expect(ids).to.include(bru.getVar("quoteId"));
  });
}
