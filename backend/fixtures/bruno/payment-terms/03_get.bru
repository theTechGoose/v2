meta {
  name: 03 get payment terms by id
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/payment-terms/{{paymentTermsId}}
  auth: none
}

tests {
  test("status is 200", function() { expect(res.getStatus()).to.equal(200); });
  test("id matches", function() { expect(res.getBody().id).to.equal(bru.getVar("paymentTermsId")); });
}
